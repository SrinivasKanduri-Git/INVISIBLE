# INVISIBLE runtime cache (created per-project under ~/.claude/invisible/<hash>/
# but ignored here in case anyone runs from inside this repo)
.invisible/
**/.invisible/

# Claude Code local settings (per-user permissions, not project-shared)
.claude/settings.local.json
.claude/cache/
.claude/logs/

# Local-only test artifacts (drafts, scratch results that aren't committed fixtures)
tests/**/scratch/
tests/**/*.local.json
tests/**/*.local.md
tests/runtime/output/

# Cloned external repos for dogfood (kept under ~/app/<repo>, never inside this tree;
# pattern below catches accidental clones into the skillset dir)
maybe/
inbox-zero/
dispatch/
external-repos/

# OS / editor noise
.DS_Store
Thumbs.db
.vscode/
.idea/
*.swp
*.swo
*~

# Python (for any future runtime build under tests/runtime/)
__pycache__/
*.py[cod]
*.egg-info/
.venv/
venv/
.pytest_cache/
.mypy_cache/
.ruff_cache/

# Node (for any future tooling)
node_modules/
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# Env files (should never be in this repo, but defense in depth)
.env
.env.*
!.env.example

# Logs
*.log
